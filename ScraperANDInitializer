# Leicester City Passing Vectors Extractor (DEBUG VERSION)
import soccerdata as sd
import pandas as pd
import warnings

warnings.filterwarnings('ignore')

def get_passing_data(match_url):
    print("\n" + "="*50)
    print("🚀 SCENE 1: FETCHING RAW DATA 🚀")
    print("="*50)

    # 1. 获取比赛 ID
    try:
        match_id = int(match_url.split('/matches/')[1].split('/')[0])
        print(f"成功解析比赛 ID: {match_id}")
    except Exception as e:
        print("网址格式不正确，请确保是 WhoScored 的比赛链接！")
        return

    print("[1/2] Checking schedule cache (Bypassing Cloudflare...)")
    ws = sd.WhoScored(leagues="ENG-Premier League", seasons="2425")
    
    print(f"[2/2] Fetching ALL Event Data for Match ID {match_id}...")
    try:
        events = ws.read_events(match_id=[match_id])
    except Exception as e:
        print(f"抓取失败: {e}")
        return

    # 将多层索引展平，变成普通的二维表
    df = events.reset_index()


    print("\n" + "="*50)
    print("RAW DATA INSPECTION")
    print("="*50)
    
    all_columns = df.columns.tolist()
    print(f"一共发现了 {len(all_columns)} 列参数，精确名称如下：")
    print(all_columns)
    
    raw_output = f'RAW_match_{match_id}_events.csv'
    df.to_csv(raw_output, index=False, encoding='utf-8-sig')
    print(f"\n已将没有任何过滤的原始数据保存到指定路径：{raw_output}")


    print("\n" + "="*50)
    print("尝试提取莱斯特城传球数据... ")
    print("="*50)
    
    try:
        # 智能匹配列名
        team_col = 'team' if 'team' in df.columns else df.columns[df.columns.str.contains('team', case=False)][0]
        type_col = 'type' if 'type' in df.columns else df.columns[df.columns.str.contains('type', case=False)][0]
        outcome_col = 'outcomeType' if 'outcomeType' in df.columns else df.columns[df.columns.str.contains('outcome', case=False)][0]
        
        is_leicester = df[team_col].astype(str).str.contains('Leicester', case=False, na=False)
        is_pass = df[type_col].astype(str).str.contains('Pass', case=False, na=False)
        is_successful = df[outcome_col].astype(str).str.contains('Successful|Success|1', case=False, na=False)
        
        pass_df = df[is_leicester & is_pass & is_successful].copy()
        print(f"提取成功！共找到 {len(pass_df)} 脚成功的传球。")
        
        # 保存过滤后的干净传球数据
        filtered_output = r"C:\Users\86185\Desktop\LEI\CLEAN_Leicester_{match_id}_passes.csv".format(match_id=match_id)
        pass_df.to_csv(filtered_output, index=False, encoding='utf-8-sig')
        print(f"干净的传球坐标数据已保存至：{filtered_output}")
        
    except Exception as e:
        print(f"\n自动过滤失败了，原因是找不到对应的参数名: {e}")


if __name__ == "__main__":
    TARGET_URL = "https://www.whoscored.com/matches/1821238/live/england-premier-league-2024-2025-leicester-wolves"
    get_passing_data(TARGET_URL)
