class NetworkAnalysis:
    def __init__(self):
        self.scraper = scraperfc.Whoscored()
        self.raw_events = None #二维表
        self.pass_events = None #二维表
        self.team_name = None 
        self.player = {} #哈希表{player_id: player_name}
        self.player_positions = {} #{player_id: (avg_x, avg_y)}
        self.pass_matrix = None 
        self.graph = None #有向图
    #

    # STEP 1:Scrape match data from WhoScored via ScraperFC
    #

    def scrape_match_data(self, match_url: str, team: str = "Leicester"):
        self.team_name = team
        print(f"[1/6] Scraping match data from WhoScored...")
        print(f"    URL: {match_url}")
        print(f"    Target team: {team}")
        
        try:
            self.raw_events = self.scraper.scrape_match(match_url)
            print(f"    Total events scraped: {len(self.raw_events)}")
        
        except Exception as e:
            print(f"    Error during scraping: {e}")
            self.raw_events = None
            return
        
        finally:
            try:
                self.scraper.close()
            except:
                pass
        self._clean_scraped_data()

    def _clean_scraped_data(self):
        if self.raw_events is None:
            print(f"    No data to clean.")
            return
        
        print(f"[2/6] Cleaning and structuring scraped data...")

        # Make a copy of the raw events to work with
        df = self.raw_events.copy()
        # Standardize column names
        col_map = {}
        for c in df.columns:
            cl = c.lower().strip()#小写去空格
            if cl in ('team', 'teamname', 'team_name'):
                col_map[c] = 'team'
            elif cl in ('player', 'playername', 'player_name'):
                col_map[c] = 'player_name'
            elif cl in ('playerid', 'player_id'):
                col_map[c] = 'player_id'
            elif cl in ('type', 'eventtype', 'event_type'):
                col_map[c] = 'event_type'
            elif cl == "x":
                col_map[c] = 'start_x'
            elif cl == "y":
                col_map[c] = 'start_y'
            elif cl in ('endx', 'end_x'):
                col_map[c] = 'end_x'
            elif cl in ('endy', 'end_y'):
                col_map[c] = 'end_y'
            elif cl in ('receuver', 'pass_recipient', 'recipient'):
                col_map[c] = 'recipient'
            elif cl in ('outcome', 'pass_outcome', 'outcome_type'):
                col_map[c] = 'outcome'
            elif cl in ('min', 'minute', 'time_minute'):
                col_map[c] = 'minute'
        df.rename(columns=col_map, inplace=True)

        # filter for the target team
        if 'team' in df.columns:
            team_mask = df['team'].str.contains(self.team_name, case=False, na=False)
            df = df[team_mask].copy()
            print(f"[2/6] Filtered to {len(df)} events for '{self.team_name}'.")
        # filter for passes only
        if 'event_type' in df.columns:
            pass_mask = df['event_type'].str.contains('Pass', case=False, na=False)
            df = df[pass_mask].copy()
            print(f"    {len(df)} pass events found.")
        # filter for successful passes only
        if 'outcome' in df.columns:
            success_mask = df['outcome'].str.contains('Successful|Success|1', case=False, na=False)
            df = df[success_mask].copy()
            print(f"    {len(df)} successful pass events found.")
        
        # keep only valid rows
        coord_cols = ['start_x', 'start_y', 'end_x', 'end_y']
        for c in coord_cols:
            if c in df.columns:
                df[c] = pd.to_numeric(df[c], errors='coerce')
        df.dropna(subset=coord_cols, inplace=True)
        self.pass_events = df.reset_index(drop=True)
